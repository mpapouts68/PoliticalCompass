# SQLite database path (default: ./data/political-compass.db under app root)
# IMPORTANT (Hostman App Platform): local disk is NOT persistent across redeploys.
# Survey/quiz result counts reset on every git pull/deploy unless you use external storage
# (e.g. Hostman Managed Database or a VPS with a persistent volume).
# If ./data is not writable, the app falls back to /tmp — also wiped on redeploy.
DATABASE_URL=file:./data/political-compass.db
# PayPal — set on Hostman (Live tab at developer.paypal.com → REST API app)
# PAYPAL_CLIENT_ID + PAYPAL_CLIENT_SECRET enable server checkout with Greek item names.
# Without the secret, hosted PayPal buttons from the dashboard are used as fallback.
PAYPAL_CLIENT_ID=your_live_client_id
PAYPAL_CLIENT_SECRET=your_live_client_secret
# Optional at build time; runtime /api/paypal/config serves PAYPAL_CLIENT_ID if omitted
# VITE_PAYPAL_CLIENT_ID=your_live_client_id
# VITE_PAYPAL_HOSTED_BUTTON_ID_350=M4MMFWH7NZFGG
# VITE_PAYPAL_HOSTED_BUTTON_ID_700=LPKAXMN846NQ4
# VITE_PAYPAL_HOSTED_BUTTON_ID_1500=5Z43NJB2V3JRN
# VITE_PAYPAL_HOSTED_BUTTON_ID_CUSTOM=JA7PXANRWQNBU