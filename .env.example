# SQLite database path (default: ./data/political-compass.db under app root)
# On Hostman if ./data is not writable, the app falls back to /tmp automatically.
DATABASE_URL=file:./data/political-compass.db
# PayPal — Live REST app credentials (developer.paypal.com → Apps → Live)
# Client ID is public (also used in browser). Secret stays server-only.
VITE_PAYPAL_CLIENT_ID=your_live_client_id
PAYPAL_CLIENT_ID=your_live_client_id
PAYPAL_CLIENT_SECRET=your_live_client_secret
# VITE_PAYPAL_HOSTED_BUTTON_ID_350=M4MMFWH7NZFGG
# VITE_PAYPAL_HOSTED_BUTTON_ID_700=LPKAXMN846NQ4
# VITE_PAYPAL_HOSTED_BUTTON_ID_1500=5Z43NJB2V3JRN
# VITE_PAYPAL_HOSTED_BUTTON_ID_CUSTOM=JA7PXANRWQNBU